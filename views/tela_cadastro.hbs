<section class="content_form">
    <h3>Cadastro titulo</h3>
    <div class="content_bane">
        <div class="box_msg">
            <p>Atenção ao preencher os campos de cadastro</p>
        </div>
        <div class="box_img"><img src="/img/6202983_3173481-removebg-preview.png" alt=""></div>
    </div>
    <form action="/cadastro/cadastro_titulo" method="post">
        <div class="box_item">
            <label for="nome">Nome:</label>
            <input type="text" id="nome" name="nome" placeholder="Nome completo">
        </div>
        <div class="box_item">
            <label for="numero_titulo">Número do Título:</label>
            <input type="number" id="numero_titulo" name="numero_titulo" placeholder="Insira o número do título">
        </div>
        <div class="box_item">
            <label for="zona">Zona:</label>
            <input type="number" id="zona" name="zona" placeholder="Insira a zona">
        </div>
        <div class="box_item">
            <label for="secao">Seção:</label>
            <select name="secao" id="secao">
                <option value="">Selecione a seção</option>
                <!-- Adicione opções aqui -->
            </select>
        </div>

        <div class="content_btn-form">
            <button type="submit">Cadastrar</button>
        </div>
    </form>


</section>